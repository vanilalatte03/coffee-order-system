#!/bin/sh

set -u

repo_root=$(git rev-parse --show-toplevel) || exit 1
cd "$repo_root" || exit 1

if ! git diff --cached --check; then
    printf '\nCommit blocked: staged files contain whitespace errors.\n' >&2
    exit 1
fi

case "$(uname -s)" in
    CYGWIN* | MINGW* | MSYS*) gradle_command='./gradlew.bat' ;;
    *) gradle_command='./gradlew' ;;
esac

if ! "$gradle_command" spotlessCheck --no-daemon; then
    printf '\nCommit blocked: formatting check failed.\n' >&2
    printf 'Run the formatter and review the changes before staging again:\n' >&2
    printf '%s\n' '  .\gradlew.bat spotlessApply' >&2
    exit 1
fi
