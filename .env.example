# MySQL
DB_URL=jdbc:mysql://localhost:3307/coffee_order?connectionTimeZone=UTC&forceConnectionTimeZoneToSession=true
DB_USERNAME=coffee
DB_PASSWORD=coffee
MYSQL_ROOT_PASSWORD=root
DB_LOCK_WAIT_TIMEOUT_SECONDS=1

# Mock data platform HTTP receiver
DATA_PLATFORM_BASE_URL=http://localhost:9090
DATA_PLATFORM_CONNECT_TIMEOUT=500ms
DATA_PLATFORM_READ_TIMEOUT=2s

# Transactional Outbox worker
OUTBOX_POLL_INTERVAL=1s
OUTBOX_LEASE=30s
OUTBOX_WORKER_ID=coffee-order-system
OUTBOX_DELIVERY_ENABLED=true
OUTBOX_AFTER_COMMIT_WAKEUP_ENABLED=true
